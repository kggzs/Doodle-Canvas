# ============================================
# Doodle-Canvas 后端配置模板
# 复制为 server/.env 后，通常只需要填写数据库、Redis 和邮件配置。
#
# 自动项：
# - JWT_SECRET / AES_SECRET_KEY 缺失时会生成到 server/.runtime.env
# - STORAGE_ROOT 默认 server/storage
# - STORAGE_BASE_URL 默认 /storage
# - 前端构建目录默认 ../../dist
# ============================================

NODE_ENV=production
PORT=3000

# MySQL（必填）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=canvas
DB_USER=canvas
DB_PASS=replace_with_mysql_password

# Redis（建议配置；密码为空可留空）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=

# 跨域来源。单服务部署同源访问时可不配置；前后端分离部署时填写前端域名。
# CORS_ORIGINS=https://example.com

# 邮件服务。需要真实发送注册验证码时填写。
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Doodle-Canvas <noreply@example.com>"

# ===== 可选覆盖项：保持注释即可使用代码默认值 =====
# SERVE_FRONTEND=true
# FRONTEND_BASE=/
# FRONTEND_DIST_DIR=../../dist
# LOG_LEVEL=info

# 手动固定密钥时再填写；留空会自动生成到 .runtime.env。
# JWT_SECRET=replace_with_at_least_32_bytes_random_secret
# JWT_ACCESS_EXPIRES=15m
# JWT_REFRESH_EXPIRES=3650d
# AES_SECRET_KEY=replace_with_exactly_32_ascii_chars
# AES_IV=legacy_16_byte_iv

# 文件存储默认 server/storage + /storage；自定义磁盘目录或 CDN 时再覆盖。
# STORAGE_ROOT=/www/wwwroot/doodle-canvas-storage
# STORAGE_BASE_URL=/storage
# STORAGE_MAX_UPLOAD_BYTES=20971520
# STORAGE_REMOTE_MAX_BYTES=104857600
# STORAGE_REMOTE_MAX_REDIRECTS=3
# STORAGE_REMOTE_DOWNLOAD_TIMEOUT_MS=60000
# STORAGE_BLOCK_BENCHMARK_IPS=true

# 注册、金币与计费默认值
# REGISTER_GIFT_COINS=100
# DEFAULT_NEW_USER_BALANCE=10.00
# DEFAULT_GENERATION_COST=0
# DEFAULT_IMAGE_COST=1
# DEFAULT_VIDEO_COST=0
# DEFAULT_CHAT_COST=0
# BILLING_LOCK_TIMEOUT_SECONDS=5

# 限流与认证降级策略
# RATE_LIMIT_GLOBAL=600
# AUTH_REDIS_FAILURE_MODE=deny
