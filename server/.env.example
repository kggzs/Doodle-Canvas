# ============================================
# Doodle-Canvas 后端服务环境变量配置示例
# 复制本文件为 .env 并填写真实值
# ============================================

# 服务器
PORT=3000
NODE_ENV=production
SERVE_FRONTEND=true
FRONTEND_BASE=/
FRONTEND_DIST_DIR=../../dist

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=canvas
DB_USER=canvas
DB_PASS=你的数据库密码

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# JWT
JWT_SECRET=你的JWT密钥-至少32位随机字符串
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# 首次创建管理员时可临时使用，也可直接通过命令参数传入
ADMIN_EMAIL=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# AES 加密（用于 API Key 加密存储）
AES_SECRET_KEY=你的AES密钥-32字节
AES_IV=你的AES初始向量-16字节

# 文件存储（v3.2：本地磁盘存储，不使用 OSS）
STORAGE_ROOT=/www/wwwroot/doodle-canvas-storage
STORAGE_BASE_URL=https://cdn.example.com/storage
# 软删除文件保留天数（超过后定时任务物理删除并写 audit_logs）
STORAGE_SOFT_DELETE_RETAIN_DAYS=90
# 单文件大小上限（字节，默认 50MB）
STORAGE_MAX_FILE_SIZE=52428800
# 允许的 MIME 类型白名单（逗号分隔）
STORAGE_ALLOWED_MIMES=image/png,image/jpeg,image/webp,image/gif,video/mp4

# 邮件服务（注册认证 / 异常登录 / 重置密码）
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=postmaster@example.com
SMTP_PASS=你的SMTP密码
MAIL_FROM="Doodle-Canvas <postmaster@example.com>"

# 金币体系
COIN_EXCHANGE_RATE=1.0
REGISTER_GIFT_COINS=100
LOW_BALANCE_THRESHOLD=1.00

# Redis 限流与风控（滑动窗口）
RATE_LIMIT_GLOBAL=600
RATE_LIMIT_LOGIN=20
LOGIN_FAIL_LOCK=5
LOGIN_LOCK_MINUTES=15

# 内容安全（云审核）
CONTENT_REVIEW_PROVIDER=aliyun_green
CONTENT_REVIEW_ACCESS_KEY=你的内容安全AK
CONTENT_REVIEW_ACCESS_SECRET=你的内容安全SK
CONTENT_REVIEW_REJECT_SCORE=0.9
CONTENT_REVIEW_REVIEW_SCORE=0.6

# 日志与链路追踪
LOG_LEVEL=info
ACCESS_LOG_SAMPLE_RATE=1.0

# CORS 白名单（逗号分隔）
CORS_ORIGINS=https://doodle-canvas.example.com

# 系统默认配置
DEFAULT_NEW_USER_BALANCE=10.00
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60000
