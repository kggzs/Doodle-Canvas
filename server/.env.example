# Runtime
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Frontend hosting by Express
SERVE_FRONTEND=true
FRONTEND_BASE=/
FRONTEND_DIST_DIR=../../dist
CORS_ORIGINS=https://example.com

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=canvas
DB_USER=canvas
DB_PASS=replace_with_mysql_password

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=
AUTH_REDIS_FAILURE_MODE=deny

# Secrets
# JWT_SECRET must be at least 32 bytes.
JWT_SECRET=replace_with_at_least_32_bytes_random_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AES_SECRET_KEY must be exactly 32 bytes; replace this 32-byte placeholder.
AES_SECRET_KEY=replace_with_32_byte_secret_key!
# AES_IV is only needed when decrypting legacy data without per-record iv.
AES_IV=

# Registration / billing defaults
REGISTER_GIFT_COINS=100
DEFAULT_NEW_USER_BALANCE=10.00
DEFAULT_GENERATION_COST=0
DEFAULT_IMAGE_COST=1
DEFAULT_VIDEO_COST=0
DEFAULT_CHAT_COST=0
BILLING_LOCK_TIMEOUT_SECONDS=5

# API rate limit
RATE_LIMIT_GLOBAL=600

# File storage
STORAGE_ROOT=/www/wwwroot/doodle-canvas-storage
STORAGE_BASE_URL=/storage
STORAGE_MAX_UPLOAD_BYTES=20971520
STORAGE_REMOTE_MAX_BYTES=104857600
STORAGE_REMOTE_MAX_REDIRECTS=3
STORAGE_REMOTE_DOWNLOAD_TIMEOUT_MS=60000
STORAGE_BLOCK_BENCHMARK_IPS=true

# SMTP email
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Doodle-Canvas <noreply@example.com>
