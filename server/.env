# ============================================
# Doodle-Canvas 后端服务本地开发环境变量
# 注意：请勿提交真实密钥到版本库
# ============================================

# 服务器
PORT=3000
NODE_ENV=development
SERVE_FRONTEND=true
FRONTEND_BASE=/
FRONTEND_DIST_DIR=../../dist

# MySQL（本地开发默认值）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=canvas
DB_USER=canvas
DB_PASS=1724464998

# Redis（本地开发默认值）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# JWT（本地开发密钥，生产环境务必替换）
JWT_SECRET=dev_jwt_secret_change_me_in_production_at_least_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AES 加密（本地开发密钥，生产环境务必替换）
AES_SECRET_KEY=dev_aes_secret_key_32bytes_change_me
AES_IV=dev_aes_iv_16byte

# 文件存储（本地开发使用项目内 storage 目录）
STORAGE_ROOT=./storage
STORAGE_BASE_URL=http://localhost:3000/storage
STORAGE_SOFT_DELETE_RETAIN_DAYS=90
STORAGE_MAX_FILE_SIZE=52428800
STORAGE_ALLOWED_MIMES=image/png,image/jpeg,image/webp,image/gif,video/mp4

# 邮件服务（本地开发占位）
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=postmaster@example.com
SMTP_PASS=
MAIL_FROM="Doodle-Canvas <postmaster@example.com>"

# 金币体系
COIN_EXCHANGE_RATE=1.0
REGISTER_GIFT_COINS=100
LOW_BALANCE_THRESHOLD=1.00

# Redis 限流与风控（滑动窗口）
RATE_LIMIT_GLOBAL=600
RATE_LIMIT_LOGIN=20
LOGIN_FAIL_LOCK=5
LOGIN_LOCK_MINUTES=15

# 内容安全（云审核）
CONTENT_REVIEW_PROVIDER=none
CONTENT_REVIEW_ACCESS_KEY=
CONTENT_REVIEW_ACCESS_SECRET=
CONTENT_REVIEW_REJECT_SCORE=0.9
CONTENT_REVIEW_REVIEW_SCORE=0.6

# 日志与链路追踪
LOG_LEVEL=debug
ACCESS_LOG_SAMPLE_RATE=1.0

# CORS 白名单（本地开发允许全部来源）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# 系统默认配置
DEFAULT_NEW_USER_BALANCE=10.00
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60000
