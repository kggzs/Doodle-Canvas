# Copy this file to .env before running docker compose in production.
# cp .env.docker.example .env

APP_PORT=3000

DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=canvas
DB_USER=canvas
DB_PASS=replace_with_strong_mysql_password

REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASS=

# JWT_SECRET: at least 32 bytes.
JWT_SECRET=replace_with_at_least_32_bytes_random_secret

# AES_SECRET_KEY: exactly 32 ASCII characters.
AES_SECRET_KEY=0123456789abcdef0123456789abcdef

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SMTP is optional unless registration email verification is required.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Doodle-Canvas <noreply@example.com>"

REGISTER_GIFT_COINS=100
DEFAULT_NEW_USER_BALANCE=10.00
DEFAULT_GENERATION_COST=0
DEFAULT_IMAGE_COST=1
DEFAULT_VIDEO_COST=0
DEFAULT_CHAT_COST=0
